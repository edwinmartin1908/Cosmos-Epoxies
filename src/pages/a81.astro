---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import Product from "../layouts/product.astro";
import image from "../assets/products/a81.png"

const product = {
  name: "COSMO-EPOXY A-81™",
  subtitle: "Anti-Corrosive Epoxy Polyamide Primer with Zinc Phosphate and Enhanced Flexibility",
  image: image.src,
  description: "COSMO-EPOXY A-81™ is a high-performance epoxy polyamide primer formulated with zinc phosphate (ZP) pigment to deliver long-term corrosion protection in demanding industrial and marine environments. This coating provides excellent adhesion to properly prepared substrates and combines toughness with flexibility, allowing it to withstand mechanical stress without compromising film integrity. It offers strong resistance to abrasion, chemical exposure including acids and alkalis, solvents, and fresh water. Free from lead and chrome-based pigments, it is a safer and environmentally responsible solution for modern protective coating systems.",
  family: "Epoxy Systems",

  benefits: [
    "Advanced anti-corrosive protection through zinc phosphate technology",
    "Excellent adhesion to steel and properly prepared substrates",
    "Balanced toughness and flexibility to resist cracking under stress",
    "High resistance to abrasion and aggressive industrial environments",
    "Outstanding chemical resistance to acids, alkalis, solvents and water",
    "Superior performance in immersion and high-humidity conditions",
    "Free from lead and chrome-based pigments for safer application",
    "Extends service life and reduces maintenance frequency"
  ],

  brand: "Cosmos Coatings",

  industries: [
    "Oil & Gas",
    "Mining",
    "Marine & Offshore",
    "Water Treatment & Storage",
    "Infrastructure & Steel Construction",
    "Petrochemical Plants"
  ],

  technology: "Epoxy Polyamide Technology reinforced with Zinc Phosphate (ZP) pigment, providing a dual protection mechanism through barrier performance and active corrosion inhibition, with enhanced flexibility for improved durability under mechanical and thermal stress.",
  
  technicalsheet:"/src/assets/products sheets/a81/technical.pdf",
  applicationsheet:"/src/assets/products sheets/a81/application.pdf",
  safetysheet:"/src/assets/products sheets/a81/safety.pdf"
};
---
<Layout>
    <Navbar/>
    <Product product={product}/>
    <Footer/>
</Layout>