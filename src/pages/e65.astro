---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import Product from "../layouts/product.astro";
import image from "../assets/products/e65.png"

const product = {
  name: "COSMO-EPOXY E-65™",
  subtitle: "High-Performance Epoxy Polyamide Enamel for Industrial and Marine Protection",
  image: image.src,
  description: "COSMO-EPOXY E-65™ is a two-component epoxy polyamide enamel designed as a high-performance topcoat for industrial and marine protective systems. Formulated with corrosion-inhibitive pigments, it provides a durable, chemically resistant finish capable of withstanding aggressive service environments. This coating delivers excellent resistance to abrasion, chemical exposure including acids, alkalis, solvents, and saline solutions, ensuring long-term protection of structural assets. Its robust film formation and durability make it ideal for applications where both protection and longevity are critical.",
  family: "Epoxy Systems",

  benefits: [
    "High-performance topcoat for severe industrial and marine environments",
    "Excellent resistance to abrasion and mechanical wear",
    "Outstanding chemical resistance to acids, alkalis, solvents, and saline solutions",
    "Enhanced corrosion protection through inhibitor pigment technology",
    "Durable film with long service life in aggressive exposure conditions",
    "Suitable for exterior exposure including offshore and marine environments",
    "Provides a protective barrier against chemical spills and splashes",
    "Compatible with a wide range of epoxy primer systems"
  ],

  brand: "Cosmos Coatings",

  industries: [
    "Oil & Gas",
    "Marine & Offshore",
    "Petrochemical",
    "Mining",
    "Infrastructure & Bridges",
    "Heavy Industrial Plants",
    "Shipbuilding"
  ],

  technology: "Two-component Epoxy Polyamide Technology with corrosion-inhibitive pigments, engineered to provide a dense, chemically resistant protective film that acts as a barrier against aggressive environments, chemical attack, and mechanical wear.",
  technicalsheet:"/src/assets/products sheets/e65/technical.pdf",
  applicationsheet:"/src/assets/products sheets/e65/application.pdf",
  safetysheet:"/src/assets/products sheets/e65/safety.pdf"
};
---
<Layout>
    <Navbar/>
    <Product product={product}/>
    <Footer/>
</Layout>