---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import Product from "../layouts/product.astro";
import image from "../assets/products/prim.png"


const product = {
  name: "COSMO-PRIM™",
  subtitle:
    "Fast-Drying Thermoplastic Acrylic Primer for Multi-Substrate Adhesion",
  image: image.src,
  description:
    "COSMO-PRIM™ is a premium-quality industrial primer formulated with fast-drying thermoplastic acrylic resins and high-grade raw materials to ensure excellent adhesion and efficient application. Designed for use on both ferrous and non-ferrous substrates, including galvanized steel and aluminum, it provides a reliable base coat with good corrosion protection and high filling capacity. Its rapid drying characteristics make it ideal for maintenance, repair, and repainting operations where productivity and turnaround time are critical.",
  family: "Primer Systems",

  benefits: [
    "Fast-drying formulation for increased productivity and reduced downtime",
    "Excellent adhesion on ferrous and non-ferrous metals",
    "Compatible with galvanized steel and aluminum substrates",
    "Good corrosion protection for general industrial applications",
    "High filling capacity to improve surface uniformity",
    "Ideal for maintenance, repair, and repainting (MRO) operations",
    "Easy application and rapid handling properties",
    "Versatile use across multiple industrial substrates",
  ],

  brand: "Cosmos Coatings",

  industries: [
    "Automotive & Transport",
    "Industrial Maintenance",
    "Metal Fabrication",
    "Logistics & Containers",
    "Infrastructure Maintenance",
    "Light Industrial Equipment",
  ],

  technology:
    "Thermoplastic Acrylic Resin Technology, engineered for rapid solvent evaporation, excellent substrate wetting, and strong adhesion across a wide range of metallic surfaces, enabling fast recoating cycles and efficient application in high-throughput environments.",

  technicalsheet: "/Cosmos-Coatings/products sheets/prim/technical.pdf",
  applicationsheet:"/Cosmos-Coatings/products sheets/prim/application.pdf",
  safetysheet:"/Cosmos-Coatings/products sheets/prim/safety.pdf"
};

---

<Layout>
  <Navbar />
  <Product product={product} />
  <Footer />
</Layout>
