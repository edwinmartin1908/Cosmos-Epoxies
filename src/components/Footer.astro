---
import "../styles/global.css";
---

<footer class="bg-[#0A1422] text-gray-300 border-t border-white/10">
  <div
    class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-2 md:grid-cols-4 gap-12"
  >
    <!-- Social -->
    <div>
      <h3 class="text-white font-semibold mb-4 tracking-wide">Social</h3>
      <div class="flex gap-5 text-xl">
        <a
          href="https://www.youtube.com/@COSMOSCOATINGS"
          target="_blank"
          class="hover:text-[#E77B00] transition"
        >
          <i class="fa-brands fa-youtube"></i>
        </a>

        <a
          href="https://www.linkedin.com/company/98321246/admin/dashboard/"
          target="_blank"
          class="hover:text-[#E77B00] transition"
        >
          <i class="fa-brands fa-linkedin"></i>
        </a>
      </div>
    </div>

    <!-- Company -->
    <div>
      <h3 class="text-white font-semibold mb-4 tracking-wide">Company</h3>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="/products" class="hover:text-white transition">
            Products
          </a>
        </li>
        <li>
          <a href="/blog" class="hover:text-white transition">
            Cosmos Learn Hub
          </a>
        </li>
      </ul>
    </div>

    <!-- Products -->
    <div>
      <h3 class="text-white font-semibold mb-4 tracking-wide">Products</h3>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="/a81" class="hover:text-white transition"
            >Cosmos Epoxy A-81</a>
        </li>
        <li>
          <a href="/b81" class="hover:text-white transition"
            >Cosmos Epoxy B-81</a>
        </li>
        <li>
          <a href="/m81" class="hover:text-white transition"
            >Cosmos Epoxy M-81</a>
        </li>
        <li>
          <a href="/poli" class="hover:text-white transition"
            >Cosmos Polyurethane</a>
        </li>
        <li>
          <a href="/prim" class="hover:text-white transition"
            >Cosmos Prim</a>
        </li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="text-white font-semibold mb-4 tracking-wide">Contact</h3>
      <ul class="space-y-2 text-sm">
        <li>Lima, Perú</li>
        <li>+51 982 546 418</li>
        <li>info@cosmosepoxies.com</li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10 text-center text-sm text-gray-400 py-6">
    © 2026 Cosmos Coatings. All rights reserved.
  </div>
</footer>
