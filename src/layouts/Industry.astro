---

import Articles from "../sections/Industry/articles.astro"
import Products from "../sections/Industry/products.astro"
// layouts/IndustryLayout.astro
const { data } = Astro.props;
---

<section class="relative w-full">
  <!-- Imagen fondo -->
  <div class="h-[520px] md:h-[620px] w-full overflow-hidden">
    <img
      src={data.heroImage}
      alt={data.heroTitle}
      class="w-full h-full object-cover"
    />
  </div>

  <!-- Contenedor -->
  <div class="max-w-[1200px] mx-auto px-5 relative">
    <!-- Caja flotante -->
    <div
      class="bg-white/95 backdrop-blur-sm shadow-xl border border-gray-200
                max-w-[720px] p-12 md:p-16
                -mt-[260px] md:-mt-[320px] relative z-10"
    >
      <!-- Industria -->
      <h1 class="text-[44px] md:text-[52px] font-light text-gray-800 mb-8">
        {data.heroTitle}
      </h1>

      <!-- Problemas -->
      <p class="text-gray-700 leading-relaxed text-[20px] md:text-[22px]">
        {data.heroText}
      </p>
    </div>
  </div>
</section>

<!-- Benefits -->
<Articles/>

<!-- Products -->
<Products/>

<!-- Gallery -->
<section
  class="max-w-[1400px] mx-auto px-5 py-16 grid grid-cols-1 md:grid-cols-3 gap-6"
>
  {
    data.gallery.map((img) => (
      <img
        src={img}
        alt="Industry visual"
        class="w-full h-60 object-cover rounded-lg shadow-lg"
      />
    ))
  }
</section>
