---
import Products from "../pages/products.astro";

const { product } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{product.name}</title>
    <link href="/Cosmos-Coatings/dist/output.css" rel="stylesheet" />
  </head>

  <body class="bg-gray-50 text-gray-800 font-sans">
    <!-- Breadcrumb -->
    <section class="max-w-[1400px] mx-auto px-6 pt-6">
      <p class="text-sm text-gray-500">
        Products / {product.family} /
        <span class="text-gray-900 font-medium">{product.name}</span>
      </p>
    </section>

    <!-- HERO -->
    <section class="max-w-[1400px] mx-auto px-6 py-20 md:py-24">
      <div class="grid md:grid-cols-5 gap-12 items-start">
        <!-- Imagen -->
        <div class="md:col-span-2 flex justify-center">
          <div class="relative">
            <!-- fondo sutil -->
            <div
              class="absolute inset-0 bg-gradient-to-br from-gray-100 to-gray-50 rounded-xl"
            >
            </div>

            <!-- imagen -->
            <img
              src={product.image}
              alt={product.name}
              class="mx-auto relative rounded-xl w-full max-w-lg object-cover border border-gray-200"
            />
          </div>
        </div>

        <!-- Contenido -->
        <div class="md:col-span-3 flex flex-col space-y-6">
          <h2
            class="text-sm font-semibold text-[#e77b00] uppercase tracking-widest"
          >
            {product.subtitle}
          </h2>

          <h1
            class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight"
          >
            {product.name}
          </h1>

          <p class="text-gray-700 leading-relaxed text-lg max-w-2xl">
            {product.description}
          </p>

          <!-- Badges -->
          <div
            class="flex flex-wrap items-center gap-x-4 gap-y-2 pt-2 text-sm text-gray-700"
          >
            {
              product.benefits.slice(0, 3).map((b) => (
                <span class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 bg-[#e77b00] rounded-full" />
                  {b}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- TABS -->
    <section class="max-w-[1400px] mx-auto px-6">
      <div class="border-b border-gray-300 relative">
        <nav class="flex space-x-8" role="tablist">
          <button
            id="overview-tab"
            role="tab"
            aria-selected="true"
            aria-controls="overview-content"
            class="tab-btn relative pb-4 text-sm font-semibold tracking-wide text-black cursor-pointer"
          >
            Product Overview
          </button>

          <button
            id="datasheet-tab"
            role="tab"
            aria-selected="false"
            aria-controls="datasheet-content"
            class="tab-btn relative pb-4 text-sm font-semibold tracking-wide text-gray-500 hover:text-gray-700 cursor-pointer"
          >
            Data Sheets
          </button>

          <span
            id="tab-indicator"
            class="absolute bottom-0 left-0 h-[2px] bg-[#e77b00] transition-all duration-300 rounded"
          ></span>
        </nav>
      </div>

      <!-- CONTENT -->
      <div id="tab-content" class="py-10 text-gray-700">
        <!-- OVERVIEW -->
        <div id="overview-content" role="tabpanel">
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
            <div class="bg-white p-5 rounded-lg border border-gray-200">
              <h3 class="font-semibold text-gray-900 mb-3">Benefits</h3>
              <ul class="space-y-2 text-sm text-gray-700">
                {product.benefits.map((b) => <li>• {b}</li>)}
              </ul>
            </div>

            <div class="bg-white p-5 rounded-lg border border-gray-200">
              <h3 class="font-semibold text-gray-900 mb-3">Brand</h3>
              <p class="text-sm text-gray-700">{product.brand}</p>
            </div>

            <div class="bg-white p-5 rounded-lg border border-gray-200">
              <h3 class="font-semibold text-gray-900 mb-3">Industry</h3>
              <ul class="space-y-2 text-sm text-gray-700">
                {product.industries.map((i) => <li>• {i}</li>)}
              </ul>
            </div>

            <div class="bg-white p-5 rounded-lg border border-gray-200">
              <h3 class="font-semibold text-gray-900 mb-3">Technology</h3>
              <p class="text-sm text-gray-700">{product.technology}</p>
            </div>
          </div>
        </div>

        <!-- DATA SHEETS (ESTILO ORIGINAL PERO LIMPIO) -->
        <div
          id="datasheet-content"
          role="tabpanel"
          class="hidden opacity-0 transition-opacity duration-500"
        >
          <h3 class="font-semibold text-gray-900 mb-4">
            {product.name} Data Sheets
          </h3>

          <ul class="list-disc list-inside space-y-2 text-gray-700">
            <li>
              <a
                href={product.technicalsheet}
                target="_blank"
                class="text-[#e77b00] hover:text-[#cc6600] underline"
              >
                Technical Data Sheet (PDF)
              </a>
            </li>
            <li>
              <a
                href={product.applicationsheet}
                target="_blank"
                class="text-[#e77b00] hover:text-[#cc6600] underline"
              >
                Application Data Sheet (PDF)
              </a>
            </li>
            <li>
              <a
                href={product.safetysheet}
                target="_blank"
                class="text-[#e77b00] hover:text-[#cc6600] underline"
              >
                Safety Data Sheet (PDF)
              </a>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <script>
      const overviewTab = document.getElementById("overview-tab");
      const datasheetTab = document.getElementById("datasheet-tab");
      const overviewContent = document.getElementById("overview-content");
      const datasheetContent = document.getElementById("datasheet-content");
      const indicator = document.getElementById("tab-indicator");

      function setIndicator(tab) {
        const rect = tab.getBoundingClientRect();
        const parentRect = tab.parentElement.getBoundingClientRect();
        indicator.style.width = rect.width + "px";
        indicator.style.transform = `translateX(${rect.left - parentRect.left}px)`;
      }

      overviewTab.addEventListener("click", () => {
        overviewContent.classList.remove("hidden");
        datasheetContent.classList.add("hidden");

        // 🔥 FIX OPACITY
        overviewContent.classList.add("opacity-100");
        datasheetContent.classList.remove("opacity-100");

        overviewTab.classList.add("text-black");
        overviewTab.classList.remove("text-gray-500");

        datasheetTab.classList.remove("text-black");
        datasheetTab.classList.add("text-gray-500");

        setIndicator(overviewTab);
      });

      datasheetTab.addEventListener("click", () => {
        datasheetContent.classList.remove("hidden");
        overviewContent.classList.add("hidden");

        // 🔥 FIX OPACITY
        datasheetContent.classList.add("opacity-100");
        overviewContent.classList.remove("opacity-100");

        datasheetTab.classList.add("text-black");
        datasheetTab.classList.remove("text-gray-500");

        overviewTab.classList.remove("text-black");
        overviewTab.classList.add("text-gray-500");

        setIndicator(datasheetTab);
      });

      window.addEventListener("load", () => setIndicator(overviewTab));
      window.addEventListener("resize", () =>
        setIndicator(document.querySelector('[aria-selected="true"]')),
      );
    </script>
  </body>
</html>
