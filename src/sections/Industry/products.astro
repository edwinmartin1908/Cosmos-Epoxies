---

import image1 from "../../assets/products/b81ind.png"
import image2 from "../../assets/products/primind.png"
---
<section class="relative bg-gray-50 py-24">

  <div class="max-w-[1400px] mx-auto px-6">

    <!-- TÍTULO -->
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-[40px] font-bold text-[#1f2c4c] mb-4">
        Industrial Epoxy Solutions
      </h2>
      <p class="text-[#375668] text-[16px] md:text-[20px] max-w-[700px] mx-auto">
        High-performance coatings engineered to protect critical infrastructure, extend equipment life, and reduce operational downtime.
      </p>
    </div>

    <!-- PRODUCT 1 -->
    <section class="grid md:grid-cols-2 gap-12 items-center mb-24">

      <!-- IMAGE -->
      <div class="group overflow-hidden rounded-2xl object-cover">
        <img src={image1.src}
          class="w-full h-[320px] md:h-[380px] object-cover transition duration-500 group-hover:scale-105">
      </div>

      <!-- CONTENT -->
      <div class="md:pl-12">

        <h3 class="text-2xl md:text-[26px] font-semibold text-[#1f2c4c] mb-3">
          COSMOS B-81™
        </h3>

        <p class="text-[#375668] text-[16px] md:text-[20px] mb-5 leading-relaxed">
          A high-build epoxy coating for environments exposed to aggressive chemicals, acids, and solvents. Perfect for tanks, pipelines, and containment areas.
        </p>

        <ul class="grid grid-cols-2 gap-3 text-[#375668] text-[16px] mb-5">
          <li>✔ Chemical resistant</li>
          <li>✔ High adhesion</li>
          <li>✔ Thick film protection</li>
          <li>✔ Long service life</li>
        </ul>

        <a href="/b81"
          class="inline-flex items-center gap-2 text-[#E77B00] text-[16px] font-semibold hover:gap-3 transition-all">
          View Product →
        </a>

      </div>

    </section>

    <!-- PRODUCT 2 -->
    <section class="grid md:grid-cols-2 gap-12 items-center">

      <!-- IMAGE -->
      <div class="group overflow-hidden rounded-2xl md:order-2">
        <img src={image2.src}
          class="w-full h-[320px] md:h-[380px] object-cover transition duration-500 group-hover:scale-105">
      </div>

      <!-- CONTENT -->
      <div class="md:pr-12 md:order-1">

        <h3 class="text-2xl md:text-[26px] font-semibold text-[#1f2c4c] mb-3">
          COSMOS M-81™
        </h3>

        <p class="text-[#375668] text-[16px] md:text-[18px] mb-5 leading-relaxed">
          Engineered to withstand extreme abrasion in mining operations. Protects equipment surfaces exposed to slurry flow and particle impact.
        </p>

        <ul class="grid grid-cols-2 gap-3 text-[#375668] text-[16px] mb-5">
          <li>✔ Abrasion resistant</li>
          <li>✔ Impact protection</li>
          <li>✔ Long durability</li>
          <li>✔ Industrial grade</li>
        </ul>

        <a href="/m81"
          class="inline-flex items-center gap-2 text-[#E77B00] text-[16px] font-semibold hover:gap-3 transition-all">
          View Product →
        </a>

      </div>

    </section>

  </div>

</section>