---
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

// shuffle
const shuffled = [...posts].sort(() => Math.random() - 0.5).slice(0, 6);
---

<section class="py-[140px] px-6 bg-[#F9FAFB]">
  <div class="max-w-[1200px] mx-auto">

    <!-- HEADER -->
    <div class="max-w-[800px] mx-auto text-center mb-[90px]">

      <span class="text-sm tracking-widest uppercase text-[#E77B00] font-semibold">
        Knowledge System
      </span>

      <h2 class="text-[44px] mt-4 font-semibold text-[#111827] leading-tight">
        Engineering intelligence for
        <span class="text-[#E77B00]">high-performance coatings</span>
      </h2>

      <p class="mt-6 text-[20px] text-gray-600 leading-relaxed">
        Deep technical insights into formulation science, corrosion protection,
        and coating performance in real industrial environments.
      </p>

    </div>

    <!-- GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[40px]">

      {
        shuffled.map((post) => (
          <a
            href={`/Cosmos-Coatings/${post.slug}`}
            class="group blog-card relative block bg-white border border-gray-200 rounded-2xl p-8 overflow-hidden cursor-pointer transition duration-300 hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(0,0,0,0.08)]"
          >

            <!-- línea técnica -->
            <div class="w-10 h-[2px] bg-[#E77B00] mb-6 transition group-hover:w-16"></div>

            {/* CATEGORY */}
            {post.data.category && (
              <span class="text-[11px] uppercase tracking-widest text-gray-500 font-semibold">
                {post.data.category}
              </span>
            )}

            {/* TITLE */}
            <h3 class="text-[22px] mt-3 mb-3 leading-snug font-semibold text-[#111827] group-hover:text-[#E77B00] transition">
              {post.data.title}
            </h3>

            {/* DESCRIPTION */}
            <p style="color:#1f2c4c;" class="text-[15px] text-gray-600 leading-relaxed">
              {post.data.description}
            </p>

            {/* CTA */}
            <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-[#111827] group-hover:text-[#E77B00] transition">
              <span>Read technical insight</span>
              <span class="group-hover:translate-x-1 transition">→</span>
            </div>

            <!-- subtle hover glow -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition pointer-events-none">
              <div class="absolute inset-0 bg-gradient-to-tr from-[#E77B00]/5 to-transparent"></div>
            </div>

          </a>
        ))
      }

    </div>

    <!-- FOOTER -->
    <div class="text-center mt-[90px]">
      <a
        href="/Cosmos-Coatings/blog"
        class="inline-flex items-center gap-2 px-8 py-3 border border-[#111827] text-[#111827] rounded-lg font-medium hover:bg-[#111827] hover:text-white transition"
      >
        Explore full knowledge base
        <span class="transition group-hover:translate-x-1">→</span>
      </a>
    </div>

  </div>
</section>
