<!-- MENU PRINCIPAL -->
<section
  class="w-full bg-white border-b border-gray-200 sticky top-0 z-30 isolate"
>
  <div class="max-w-[1400px] mx-auto px-6">
    <div id="main-menu" class="flex items-center gap-6 py-5 overflow-x-auto">
      <button
        data-category="all"
        class="menu-btn group relative text-[16px] font-semibold text-gray-900 pb-2 active"
      >
        All
        <span class="underline"></span>
      </button>

      <button
        data-category="properties"
        class="menu-btn group relative text-[16px] font-medium text-gray-500 hover:text-gray-900 pb-2"
      >
        Coating properties <span class="count ml-2 text-xs text-gray-400"
        ></span>
        <span class="underline"></span>
      </button>

      <button
        data-category="preparation"
        class="menu-btn group relative text-[16px] font-medium text-gray-500 hover:text-gray-900 pb-2"
      >
        Substrate preparation <span class="count ml-2 text-xs text-gray-400"
        ></span>
        <span class="underline"></span>
      </button>

      <button
        data-category="formulation"
        class="menu-btn group relative text-[16px] font-medium text-gray-500 hover:text-gray-900 pb-2"
      >
        Formulation <span class="count ml-2 text-xs text-gray-400"></span>
        <span class="underline"></span>
      </button>

      <button
        data-category="technology"
        class="menu-btn group relative text-[16px] font-medium text-gray-500 hover:text-gray-900 pb-2"
      >
        New technologies <span class="count ml-2 text-xs text-gray-400"></span>
        <span class="underline"></span>
      </button>

      <button
        data-category="dictionary"
        class="menu-btn group relative text-[16px] font-medium text-gray-500 hover:text-gray-900 pb-2"
      >
        Dictionary
        <span class="underline"></span>
      </button>
    </div>
  </div>
</section>

<!-- ARTICLES -->
<section id="articles-section" class="max-w-[1400px] mx-auto px-6 pt-16 pb-10">
  <h1 class="text-5xl font-semibold text-[#111827]">Articles</h1>
  <p class="text-lg text-gray-500 mt-3 mb-6">
    Hidden gems from coating science
  </p>
  <div id="sub-menu" class="flex flex-wrap gap-3 mt-6"></div>
</section>

<!-- DICTIONARY -->
<section
  id="dictionary-section"
  class="hidden max-w-[1400px] mx-auto px-6 pt-16 pb-16 min-h-screen"
>
  <div class="grid md:grid-cols-[1fr_460px] gap-20">
    <div class="max-h-[800px] overflow-y-auto pr-4">
      <h1 class="text-4xl font-semibold mb-4">Dictionary</h1>
      <p class="text-gray-500 mb-6">Explore key concepts in coating science.</p>
      <input
        id="dictionary-search"
        type="text"
        placeholder="Search concept..."
        class="w-full mb-6 px-4 py-3 border rounded-lg focus:outline-none focus:border-[#E77B00] focus:ring-2 focus:ring-[#E77B00]/20 transition-all"
      />

      <div
        id="dictionary-container"
        class="grid grid-cols-2 md:grid-cols-3 gap-6"
      >
      </div>
    </div>

    <div class="sticky top-24 h-fit z-10">
      <div
        id="definition-content"
        class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm transition-all"
      >
        <h2 class="text-2xl font-semibold mb-2 text-gray-400">
          Select a concept
        </h2>
        <p class="text-gray-400">Click on any term to see its definition.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .menu-btn {
    cursor: pointer;
    position: relative;
    white-space: nowrap;
    transition: all 0.25s ease;
  }

  .menu-btn .underline {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 2px;
    width: 100%;
    background: #e77b00;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .menu-btn:hover .underline {
    transform: scaleX(1);
  }

  .menu-btn.active {
    color: #111827;
    font-weight: 600;
  }

  .menu-btn.active .underline {
    transform: scaleX(1);
  }

  #dictionary-search {
    border: 1px solid #d1d5db;
  }

  #dictionary-search:focus {
    border-color: #e77b00;
    box-shadow: 0 0 0 2px rgba(231, 123, 0, 0.15);
  }

  .term-item {
    padding: 8px 12px;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 500;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.25s ease;
    background: #fafafa;
  }

  .term-item:hover {
    background: #f9f9f9;
    transform: translateX(4px);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
  }

  .term-item.active {
  background: rgba(231, 123, 0, 0.1);
  color: #111827;
  font-weight: 600;
}
  .arrow {
    font-size: 14px;
    opacity: 0.5;
    transition: all 0.2s;
  }

  .term-item:hover .arrow {
    transform: translateX(4px);
    opacity: 1;
  }

  #dictionary-container h2 {
    margin-bottom: 0.5rem;
    font-size: 1rem;
    color: #6b7280;
  }
</style>

