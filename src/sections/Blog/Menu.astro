  const mainButtons = document.querySelectorAll("#main-menu button");
  const subMenu = document.getElementById("sub-menu");
  const cards = document.querySelectorAll(".blog-card");

  const articlesSection = document.getElementById("articles-section");
  const dictionarySection = document.getElementById("dictionary-section");

  // ✅ FIX: ahora "All" también cuenta
  function updateCategoryCounts() {
    mainButtons.forEach((button) => {
      const category = button.dataset.category;

      // 🔥 ALL
      if (category === "all") {
        const count = cards.length;
        const span = button.querySelector(".count");

        // si no existe el span, lo creamos
        if (!span) {
          const newSpan = document.createElement("span");
          newSpan.className = "count";
          newSpan.textContent = ` (${count})`;
          button.appendChild(newSpan);
        } else {
          span.textContent = `(${count})`;
        }

        return;
      }

      if (category === "dictionary") return;

      const relatedSubcategories = subcategories[category] || [];

      const slugs = relatedSubcategories.map((sub) =>
        sub.toLowerCase().replaceAll(" ", "-"),
      );

      const count = [...cards].filter((card) =>
        slugs.includes(card.dataset.subcategory),
      ).length;

      const span = button.querySelector(".count");
      if (span) span.textContent = `(${count})`;
    });
  }

  function renderSubcategories(list, category = "all") {
  subMenu.innerHTML = "";

  list.forEach((item, index) => {
    const slug = item.toLowerCase().replaceAll(" ", "-");

    const count = [...cards].filter(
      (card) => card.dataset.subcategory === slug,
    ).length;

    const btn = document.createElement("button");

    btn.dataset.subcategory = slug;

    btn.className = `
      sub-btn relative text-[14px] font-medium text-gray-600
      pr-3 py-1.5 rounded-md
      cursor-pointer
      transition-all duration-200 ease-out
      hover:text-gray-900 hover:after:h-[2px]
      after:content-[''] after:absolute after:left-0 after:-bottom-[2px]
      after:w-full after:h-[2px]
      after:bg-[#e77b00]
      after:scale-x-0 after:origin-left
      after:transition-transform after:duration-300
      after:h-[1.5px]
      hover:after:scale-x-100
    `;

    btn.innerHTML = `${item} <span class="ml-1 text-xs text-gray-400">(${count})</span>`;

    // ✅ Solo activar si no es 'all' y hay cards filtrados
    if (category !== "all" && index === 0 && count > 0) {
      btn.classList.add("active");
    }

    subMenu.appendChild(btn);
  });
}
  function filterCards(category) {
    if (category === "all") {
      cards.forEach((card) => (card.style.display = "block"));
      return;
    }

    const relatedSubcategories = subcategories[category] || [];

    const slugs = relatedSubcategories.map((sub) =>
      sub.toLowerCase().replaceAll(" ", "-"),
    );

    cards.forEach((card) => {
      card.style.display = slugs.includes(card.dataset.subcategory)
        ? "block"
        : "none";
    });
  }

  function groupAlphabetically(data) {
    const grouped = {};
    data.forEach((item) => {
      const letter = item.name[0].toUpperCase();
      if (!grouped[letter]) grouped[letter] = [];
      grouped[letter].push(item);
    });
    return grouped;
  }

  function renderDictionary(filter = "") {
    const container = document.getElementById("dictionary-container");
    const panel = document.getElementById("definition-content");

    container.innerHTML = "";

    const filtered = dictionaryData.filter((d) =>
      d.name.toLowerCase().includes(filter.toLowerCase()),
    );

    const grouped = groupAlphabetically(filtered);

    Object.keys(grouped)
      .sort()
      .forEach((letter) => {
        const section = document.createElement("div");

        section.innerHTML = `
        <h2 class="text-lg font-semibold text-gray-500 mb-3">${letter}</h2>
        <div class="space-y-2">
          ${grouped[letter]
            .map(
              (item) => `
            <div class="term-item" data-name="${item.name}">
              <span class="cursor-pointer">${item.name}</span>
              <span class="arrow cursor-pointer">→</span>
            </div>
          `,
            )
            .join("")}
        </div>
      `;

        container.appendChild(section);
      });

    const items = document.querySelectorAll(".term-item");

    items.forEach((item) => {
      item.addEventListener("click", () => {
        items.forEach((i) => i.classList.remove("active"));
        item.classList.add("active");

        const data = dictionaryData.find((d) => d.name === item.dataset.name);

        panel.innerHTML = `
          <h2 class="text-3xl font-semibold mb-4">${data.name}</h2>
          <p class="text-gray-600 leading-relaxed">${data.definition}</p>
        `;
      });
    });
  }

  const allSubcategories = Object.values(subcategories).flat();

  renderSubcategories(allSubcategories);
  updateCategoryCounts();

  mainButtons.forEach((button) => {
    button.addEventListener("click", () => {
      mainButtons.forEach((btn) => btn.classList.remove("active"));
      button.classList.add("active");

      const category = button.dataset.category;

      if (category === "dictionary") {
        articlesSection.classList.add("hidden");
        dictionarySection.classList.remove("hidden");
        renderDictionary();
        cards.forEach((c) => (c.style.display = "none"));
        return;
      }

      dictionarySection.classList.add("hidden");
      articlesSection.classList.remove("hidden");

      filterCards(category);

      renderSubcategories(
        category === "all" ? allSubcategories : subcategories[category],
      );
    });
  });

  subMenu.addEventListener("click", (event) => {
    const button = event.target.closest("button");
    if (!button || !button.dataset.subcategory) return;

    // 🔥 remover active de todos
    const allSubBtns = subMenu.querySelectorAll(".sub-btn");
    allSubBtns.forEach((btn) => btn.classList.remove("active"));

    // 🔥 activar el clickeado
    button.classList.add("active");

    // 🔥 filtrar cards
    cards.forEach((card) => {
      card.style.display =
        card.dataset.subcategory === button.dataset.subcategory
          ? "block"
          : "none";
    });
  });

  document
    .getElementById("dictionary-search")
    .addEventListener("input", (e) => {
      renderDictionary(e.target.value);
    });

  function getTermFromURL() {
    const params = new URLSearchParams(window.location.search);
    return params.get("term");
  }

  window.addEventListener("DOMContentLoaded", () => {
    const term = getTermFromURL();
    if (!term) return;

    const dictionaryBtn = document.querySelector(
      '[data-category="dictionary"]',
    );

    if (dictionaryBtn) {
      dictionaryBtn.click();
    }

    setTimeout(() => {
      const items = document.querySelectorAll(".term-item");
      const panel = document.getElementById("definition-content");

      items.forEach((item) => {
        const slug = item.dataset.name.toLowerCase().replaceAll(" ", "-");

        if (slug === term) {
          item.classList.add("active");

          const data = dictionaryData.find((d) => d.name === item.dataset.name);

          if (data && panel) {
            panel.innerHTML = `
              <h2 class="text-3xl font-semibold mb-4">${data.name}</h2>
              <p class="text-gray-600 leading-relaxed">${data.definition}</p>
            `;
          }

          item.scrollIntoView({ behavior: "smooth", block: "center" });
        }
      });
    }, 400);
  });
</script>
